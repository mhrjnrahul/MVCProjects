@model List<MVCATMwithDB.Models.Transaction>

@{
    ViewData["Title"] = "Mini Statement";
}

<div class="container mt-4">
    <div class="card shadow-lg">
        <div class="card-header bg-secondary text-white">
            <h2>📄 Mini Statement - Last 10 Transactions</h2>
        </div>
        <div class="card-body">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Date & Time</th>
                                <th>Transaction Type</th>
                                <th>Amount</th>
                                <th>Balance After</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var trans in Model)
                            {
                                <tr>
                                    <td>@trans.TransactionDate.ToString("MMM dd, yyyy HH:mm")</td>
                                    <td>@trans.TransactionType</td>
                                    <td>
                                        @if (trans.Amount.HasValue)
                                        {
                                            <span class="@(trans.TransactionType == "Withdrawal" ? "text-danger fw-bold" : "text-success fw-bold")">
                                                @(trans.TransactionType == "Withdrawal" ? "-" : "+")$@trans.Amount.Value.ToString("N2")
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">N/A</span>
                                        }
                                    </td>
                                    <td class="fw-bold">$@trans.BalanceAfter?.ToString("N2")</td>
                                    <td>
                                        <span class="badge bg-@(trans.Status == "Success" ? "success" : "danger")">
                                            @trans.Status
                                        </span>
                                        @if (!string.IsNullOrEmpty(trans.FailureReason))
                                        {
                                            <br />
                                            <small class="text-danger">@trans.FailureReason</small>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info text-center">
                    <h4>No transactions found</h4>
                </div>
            }

            <div class="text-center mt-3">
                <a href="@Url.Action("Dashboard")" class="btn btn-primary btn-lg">
                    ← Back to Dashboard
                </a>
            </div>
        </div>
    </div>
</div>
