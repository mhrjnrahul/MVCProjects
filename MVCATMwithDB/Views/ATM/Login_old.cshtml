@{
    ViewData["Title"] = "ATM Login";
}

<div class="container">
    <div class="row justify-content-center align-items-center min-vh-100">
        <div class="col-md-5">
            <div class="card border-0 shadow-lg rounded-4">
                <!-- Card Header -->
                <div class="card-header bg-gradient-primary text-white text-center py-4 border-0">
                    <div class="d-flex align-items-center justify-content-center mb-2">

                        <h4 class="fw-bold mb-0">ATM Login</h4>
                    </div>
                    <p class="mb-0 opacity-75 small">Secure Banking Portal</p>
                </div>

                <!-- Card Body -->
                <div class="card-body p-4 p-md-5">
                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show rounded-3 mb-4" role="alert">
                            <div class="d-flex align-items-center">
                                <svg width="18" height="18" class="me-2 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <circle cx="12" cy="12" r="10" />
                                    <line x1="12" y1="8" x2="12" y2="12" />
                                    <line x1="12" y1="16" x2="12.01" y2="16" />
                                </svg>
                                <div>@ViewBag.Error</div>
                                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
                            </div>
                        </div>
                    }

                    <form method="post" asp-action="Login">
                        <!-- Account Number -->
                        <div class="mb-4">
                            <label class="form-label fw-medium text-secondary mb-2">Account Number</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#6c757d" stroke-width="2">
                                        <path d="M20 21V19C20 16.7909 18.2091 15 16 15H8C5.79086 15 4 16.7909 4 19V21" />
                                        <circle cx="12" cy="7" r="4" />
                                    </svg>
                                </span>
                                <input type="text"
                                       class="form-control border-start-0"
                                       name="accountNumber"
                                       placeholder="Enter account number"
                                       required
                                       autofocus />
                            </div>
                        </div>

                        <!-- PIN -->
                        <div class="mb-4">
                            <label class="form-label fw-medium text-secondary mb-2">PIN</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#6c757d" stroke-width="2">
                                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                                        <path d="M7 11V7C7 4.23858 9.23858 2 12 2C14.7614 2 17 4.23858 17 7V11" />
                                    </svg>
                                </span>
                                <input type="password"
                                       class="form-control border-start-0"
                                       name="pin"
                                       placeholder="Enter 4-digit PIN"
                                       maxlength="4"
                                       required />
                            </div>
                        </div>

                        <!-- Submit Button -->
                        <div class="d-grid mt-4">
                            <button type="submit" class="btn btn-primary btn-lg fw-medium">

                                Login
                            </button>
                        </div>
                    </form>

                    <!-- Test Credentials -->
                    <div class="mt-4 pt-4 border-top text-center">
                        <p class="text-muted mb-1 small">Demo Credentials</p>
                        <div class="d-flex justify-content-center gap-3">
                            <span class="badge bg-secondary bg-opacity-10 text-secondary px-3 py-2 rounded-3">
                                <strong>Account:</strong> ACC-1001
                            </span>
                            <span class="badge bg-secondary bg-opacity-10 text-secondary px-3 py-2 rounded-3">
                                <strong>PIN:</strong> 1234
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Modern Color Scheme */
    .bg-gradient-primary {
        background: linear-gradient(135deg, #4361ee 0%, #3a0ca3 100%) !important;
    }

    /* Card Styling */
    .card {
        border: 1px solid rgba(0, 0, 0, 0.08);
    }

    .rounded-4 {
        border-radius: 1rem !important;
    }

    /* Input Styling */
    .input-group-text {
        background-color: white;
        border-color: #dee2e6;
    }

    .form-control {
        border-color: #dee2e6;
        border-left: 0;
        padding: 0.75rem 1rem;
    }

        .form-control:focus {
            box-shadow: 0 0 0 0.2rem rgba(67, 97, 238, 0.15);
            border-color: #4361ee;
        }

    .input-group:focus-within .input-group-text {
        border-color: #4361ee;
    }

    /* Button Styling */
    .btn-primary {
        background-color: #4361ee;
        border-color: #4361ee;
        padding: 0.75rem;
    }

        .btn-primary:hover {
            background-color: #3a56d4;
            border-color: #3a56d4;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(67, 97, 238, 0.3);
        }

    /* Alert Styling */
    .alert {
        border: none;
        border-radius: 0.5rem;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .container {
            padding: 1rem;
        }

        .card-body {
            padding: 1.5rem !important;
        }

        .d-flex.gap-3 {
            flex-direction: column;
            gap: 0.5rem !important;
        }
    }

    /* Smooth transitions */
    .form-control,
    .btn,
    .badge {
        transition: all 0.2s ease;
    }
</style>