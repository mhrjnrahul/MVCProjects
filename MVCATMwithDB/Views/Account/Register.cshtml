@model MVCATMwithDB.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Register New Account";
}

<div class="container">
    <div class="row justify-content-center align-items-center min-vh-100 py-5">
        <div class="col-md-7 col-lg-6">
            <div class="card border-0 shadow-lg rounded-4">
                <!-- Card Header -->
                <div class="card-header bg-gradient-primary text-white text-center py-4 border-0">
                    <div class="d-flex align-items-center justify-content-center mb-2">
                        <h4 class="fw-bold mb-0">Create New Account</h4>
                    </div>
                    <p class="mb-0 opacity-75 small">Register for Secure Banking</p>
                </div>

                <!-- Card Body -->
                <div class="card-body p-4 p-md-5">
                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show rounded-3 mb-4" role="alert">
                            <div class="d-flex align-items-center">
                                <svg width="18" height="18" class="me-2 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <circle cx="12" cy="12" r="10" />
                                    <line x1="12" y1="8" x2="12" y2="12" />
                                    <line x1="12" y1="16" x2="12.01" y2="16" />
                                </svg>
                                <div>@ViewBag.Error</div>
                                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
                            </div>
                        </div>
                    }

                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <form method="post" asp-action="Register" asp-antiforgery="true">
                        <!-- Full Name -->
                        <div class="mb-3">
                            <label asp-for="FullName" class="form-label fw-medium text-secondary mb-2"></label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#6c757d" stroke-width="2">
                                        <path d="M20 21V19C20 16.7909 18.2091 15 16 15H8C5.79086 15 4 16.7909 4 19V21" />
                                        <circle cx="12" cy="7" r="4" />
                                    </svg>
                                </span>
                                <input asp-for="FullName" class="form-control border-start-0" placeholder="Enter your full name" />
                            </div>
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>

                        <!-- Email -->
                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-medium text-secondary mb-2"></label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#6c757d" stroke-width="2">
                                        <path d="M4 4H20C21.1 4 22 4.9 22 6V18C22 19.1 21.1 20 20 20H4C2.9 20 2 19.1 2 18V6C2 4.9 2.9 4 4 4Z" />
                                        <polyline points="22,6 12,13 2,6" />
                                    </svg>
                                </span>
                                <input asp-for="Email" class="form-control border-start-0" placeholder="your@email.com" />
                            </div>
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <!-- Account Number -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="AccountNumber" class="form-label fw-medium text-secondary mb-2"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white border-end-0">
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#6c757d" stroke-width="2">
                                            <rect x="1" y="4" width="22" height="16" rx="2" ry="2" />
                                            <line x1="1" y1="10" x2="23" y2="10" />
                                        </svg>
                                    </span>
                                    <input asp-for="AccountNumber" class="form-control border-start-0" placeholder="ACC-XXXX" />
                                </div>
                                <span asp-validation-for="AccountNumber" class="text-danger small"></span>
                            </div>

                            <!-- PIN -->
                            <div class="col-md-6 mb-3">
                                <label asp-for="PIN" class="form-label fw-medium text-secondary mb-2"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white border-end-0">
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#6c757d" stroke-width="2">
                                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                                            <path d="M7 11V7C7 4.23858 9.23858 2 12 2C14.7614 2 17 4.23858 17 7V11" />
                                        </svg>
                                    </span>
                                    <input asp-for="PIN" type="password" class="form-control border-start-0" placeholder="4-digit PIN" maxlength="4" />
                                </div>
                                <span asp-validation-for="PIN" class="text-danger small"></span>
                            </div>
                        </div>

                        <!-- Password -->
                        <div class="mb-3">
                            <label asp-for="Password" class="form-label fw-medium text-secondary mb-2"></label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#6c757d" stroke-width="2">
                                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                                        <path d="M7 11V7C7 4.23858 9.23858 2 12 2C14.7614 2 17 4.23858 17 7V11" />
                                    </svg>
                                </span>
                                <input asp-for="Password" type="password" class="form-control border-start-0" placeholder="Minimum 6 characters" />
                            </div>
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <!-- Confirm Password -->
                        <div class="mb-3">
                            <label asp-for="ConfirmPassword" class="form-label fw-medium text-secondary mb-2"></label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#6c757d" stroke-width="2">
                                        <polyline points="20 6 9 17 4 12" />
                                    </svg>
                                </span>
                                <input asp-for="ConfirmPassword" type="password" class="form-control border-start-0" placeholder="Re-enter password" />
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>

                        <!-- Initial Deposit -->
                        <div class="mb-4">
                            <label asp-for="InitialDeposit" class="form-label fw-medium text-secondary mb-2"></label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0">$</span>
                                <input asp-for="InitialDeposit" type="number" step="0.01" min="0" class="form-control border-start-0" placeholder="0.00" />
                            </div>
                            <span asp-validation-for="InitialDeposit" class="text-danger small"></span>
                            <div class="form-text">Optional: Add funds to your account</div>
                        </div>

                        <!-- Submit Button -->
                        <div class="d-grid mt-4">
                            <button type="submit" class="btn btn-primary btn-lg fw-medium">
                                Create Account
                            </button>
                        </div>
                    </form>

                    <!-- Already have account -->
                    <div class="mt-4 pt-4 border-top text-center">
                        <p class="text-muted mb-0">
                            Already have an account?
                            <a asp-action="Login" class="text-decoration-none fw-medium">Login here</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Modern Color Scheme */
    .bg-gradient-primary {
        background: linear-gradient(135deg, #4361ee 0%, #3a0ca3 100%) !important;
    }

    /* Card Styling */
    .card {
        border: 1px solid rgba(0, 0, 0, 0.08);
    }

    .rounded-4 {
        border-radius: 1rem !important;
    }

    /* Input Styling */
    .input-group-text {
        background-color: white;
        border-color: #dee2e6;
    }

    .form-control {
        border-color: #dee2e6;
        padding: 0.75rem 1rem;
    }

        .form-control:focus {
            box-shadow: 0 0 0 0.2rem rgba(67, 97, 238, 0.15);
            border-color: #4361ee;
        }

    .input-group:focus-within .input-group-text {
        border-color: #4361ee;
    }

    .border-start-0 {
        border-left: 0 !important;
    }

    .border-end-0 {
        border-right: 0 !important;
    }

    /* Button Styling */
    .btn-primary {
        background-color: #4361ee;
        border-color: #4361ee;
        padding: 0.75rem;
    }

        .btn-primary:hover {
            background-color: #3a56d4;
            border-color: #3a56d4;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(67, 97, 238, 0.3);
        }

    /* Alert Styling */
    .alert {
        border: none;
        border-radius: 0.5rem;
    }

    /* Link Styling */
    a {
        color: #4361ee;
    }

        a:hover {
            color: #3a56d4;
        }

    /* Responsive */
    @@media (max-width: 768px) {
        .container {
            padding: 1rem;
        }

        .card-body {
            padding: 1.5rem !important;
        }
    }

    /* Smooth transitions */
    .form-control,
    .btn,
    .input-group-text {
        transition: all 0.2s ease;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
