@model ProfileMgmtSystem.Models.Person

<h2>Edit Person</h2>

<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" value="@Model.Id" />
    <div class="mb-3">
        <label>First Name</label>
        <input type="text" name="firstName" value="@Model.FirstName" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Last Name</label>
        <input type="text" name="lastName" value="@Model.LastName" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Email</label>
        <input type="email" name="email" value="@Model.Email" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Date of Birth</label>
        <input type="date" name="dateOfBirth" value="@Model.DateOfBirth" class="form-control" />
    </div>
    <button type="submit" class="btn btn-warning">Save Changes</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>