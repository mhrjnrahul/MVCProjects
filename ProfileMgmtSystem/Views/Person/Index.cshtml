@model IEnumerable<ProfileMgmtSystem.Models.Person>

<div class="d-flex justify-content-between align-content-center">
    <h2>All Persons</h2>
    <a asp-action="Create" class="btn btn-primary mb-3">+ Add Person</a>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Full Name</th>
            <th>Email</th>
            <th>Age</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var person in Model)
        {
            <tr>
                <td>@person.FullName</td>
                <td>@person.Email</td>
                <td>@person.Age</td>
                <td>
                    <a asp-action="Details" asp-route-id="@person.Id" class="btn btn-sm btn-info">Details</a>
                    <a asp-action="Edit" asp-route-id="@person.Id" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@person.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>